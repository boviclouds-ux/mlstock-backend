# ═══════════════════════════════════════════════════════════════════
# .env.example  ·  Template des variables d'environnement
#
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Générer des secrets forts :
#        openssl rand -hex 32   → pour les mots de passe MongoDB
#        openssl rand -hex 64   → pour JWT_SECRET
#   3. NE JAMAIS committer .env dans Git (il est dans .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ─── MongoDB : compte administrateur ────────────────────────────────
# Utilisé UNIQUEMENT pour la gestion interne de MongoDB (pas par l'API).
MONGO_ROOT_USER=mongo_admin
MONGO_ROOT_PASSWORD=CHANGEME_openssl_rand_hex_32

# ─── MongoDB : compte applicatif (droits readWrite uniquement) ──────
# C'est ce compte qui est utilisé dans MONGO_URI de l'API.
MONGO_APP_USER=mlstock_app
MONGO_APP_PASSWORD=CHANGEME_openssl_rand_hex_32

# ─── MongoDB : base de données ──────────────────────────────────────
MONGO_DB_NAME=mlstockdb

# ─── API Node.js ─────────────────────────────────────────────────────
# Clé secrète JWT — DOIT être longue et aléatoire
JWT_SECRET=CHANGEME_openssl_rand_hex_64

# URL du frontend (pour la whitelist CORS dans server.js)
FRONTEND_URL=http://localhost

# ─── Optionnel : production ──────────────────────────────────────────
# SERVER_NAME=mlstock.votredomaine.com
